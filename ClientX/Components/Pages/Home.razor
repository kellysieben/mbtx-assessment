@page "/"
@using ClientX.Models
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IConfiguration Configuration

<PageTitle>Greenhouse Monitor X</PageTitle>

<h1 class="mb-4">Greenhouse Monitor X</h1>

<div class="table-responsive">
	<table class="table table-striped table-hover align-middle mb-0">
		<thead>
			<tr>
				<th scope="col">Timestamp</th>
				<th scope="col">Sensor</th>
				<th scope="col">Sequence</th>
				<th scope="col">Temperature</th>
				<th scope="col">Humidity</th>
				<th scope="col">CO2 (ppm)</th>
			</tr>
		</thead>
		<tbody>
			@if (readings.Count == 0)
			{
				<tr>
					<td colspan="6">@emptyStateMessage</td>
				</tr>
			}
			else
			{
				@foreach (var reading in readings)
				{
					<tr>
						<td>@reading.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
						<td>@reading.SensorId</td>
						<td>@reading.SequenceNumber</td>
						<td>@reading.Temperature</td>
						<td>@reading.Humidity</td>
						<td>@reading.Co2Ppm</td>
					</tr>
				}
			}
		</tbody>
	</table>
</div>

@code {
	private readonly List<SensorReading> readings = [];
	private readonly string instanceId = Guid.NewGuid().ToString("N")[..8];
	private HubConnection? hubConnection;
	private bool connectionStartAttempted;
	private bool disposed;
	private string emptyStateMessage = "Waiting for sensor readings...";

	protected override void OnInitialized()
	{
		Log("OnInitialized");
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender)
		{
			return;
		}

		Log("OnAfterRenderAsync(firstRender=true) - interactive lifecycle reached");
		await StartHubConnectionAsync();
	}

	private async Task StartHubConnectionAsync()
	{
		if (disposed)
		{
			Log("Skipping connection start because component is already disposed");
			return;
		}

		if (connectionStartAttempted)
		{
			Log("Skipping connection start because it was already attempted");
			return;
		}

		connectionStartAttempted = true;
		var hubUrl = Configuration["SignalR:SensorHubUrl"] ?? "http://localhost:5241/hubs/sensor";
		emptyStateMessage = "Connecting to sensor hub...";
		Log($"Preparing HubConnection to {hubUrl}");

		hubConnection = new HubConnectionBuilder()
			.WithUrl(hubUrl)
			.WithAutomaticReconnect()
			.Build();

		hubConnection.On<SensorReading>("sensorReadingAvailable", reading =>
		{
			Log($"Received sensor reading SensorId={reading.SensorId}, Timestamp={reading.Timestamp:O}, Sequence={reading.SequenceNumber}");
			AddReading(reading);
			emptyStateMessage = "Waiting for sensor readings...";
			return InvokeAsync(StateHasChanged);
		});

		hubConnection.Reconnecting += error =>
		{
			Log($"Hub reconnecting. Reason={error?.Message ?? "none"}");
			emptyStateMessage = "Reconnecting to sensor hub...";
			return InvokeAsync(StateHasChanged);
		};

		hubConnection.Reconnected += connectionId =>
		{
			Log($"Hub reconnected. ConnectionId={connectionId ?? "null"}");
			emptyStateMessage = "Waiting for sensor readings...";
			return InvokeAsync(StateHasChanged);
		};

		hubConnection.Closed += error =>
		{
			Log($"Hub closed. State={hubConnection?.State}. Reason={error?.Message ?? "none"}");
			emptyStateMessage = error is null
				? "Connection to the sensor hub closed."
				: $"Connection to the sensor hub closed: {error.Message}";
			return InvokeAsync(StateHasChanged);
		};

		try
		{
			Log("Starting HubConnection");
			await hubConnection.StartAsync();
			Log($"HubConnection started successfully. State={hubConnection.State}");
			emptyStateMessage = "Waiting for sensor readings...";
			await InvokeAsync(StateHasChanged);
		}
		catch (Exception ex)
		{
			Log($"HubConnection start failed: {ex}");
			emptyStateMessage = $"Unable to connect to the sensor hub: {ex.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	private void AddReading(SensorReading reading)
	{
		Log($"Adding reading Id={reading.Id}, Timestamp={reading.Timestamp:O}, Sequence={reading.SequenceNumber}");
		if (readings.Any(existing => existing.Id == reading.Id))
		{
			Log($"Skipping duplicate reading Id={reading.Id}");
			return;
		}

		var insertIndex = readings.FindIndex(existing => ShouldInsertBefore(reading, existing));
		if (insertIndex < 0)
		{
			readings.Add(reading);
			return;
		}

		readings.Insert(insertIndex, reading);
	}

	private void Log(string message)
	{
		Console.WriteLine($"{DateTimeOffset.UtcNow:O} Home[{instanceId}] {message}");
	}

	private static bool ShouldInsertBefore(SensorReading candidate, SensorReading existing)
	{
		if (candidate.Timestamp != existing.Timestamp)
		{
			return candidate.Timestamp > existing.Timestamp;
		}

		return candidate.SequenceNumber > existing.SequenceNumber;
	}

	public async ValueTask DisposeAsync()
	{
		disposed = true;
		Log($"DisposeAsync called. HubState={hubConnection?.State}");

		if (hubConnection is not null)
		{
			if (hubConnection.State != HubConnectionState.Disconnected)
			{
				Log("Stopping HubConnection before dispose");
				await hubConnection.StopAsync();
			}

			Log("Disposing HubConnection");
			await hubConnection.DisposeAsync();
			Log("HubConnection disposed");
		}
	}
}
